## SW01

```cisco
enable
conf t

hostname LAB-RA04-A01-SW01

vlan 1
 name Management

vlan 2
 name Data_Users

interface gig1/0/20
 switchport mode trunk

interface gig1/0/2
 switchport mode access
 switchport access vlan 2
 spanning-tree portfast

interface vlan 1
 ip address 172.17.4.4 255.255.255.240
 no shutdown

ip default-gateway 172.17.4.1

end
```
